# LINE Messaging API
LINE_CHANNEL_SECRET=your_line_channel_secret
LINE_CHANNEL_ACCESS_TOKEN=your_line_channel_access_token

# Anthropic Claude API
ANTHROPIC_API_KEY=your_anthropic_api_key
# 任意。未指定なら claude-sonnet-4-5 を使う
ANTHROPIC_MODEL=claude-sonnet-4-5

# Azure Database for MySQL (Flexible Server)
MYSQL_HOST=tech0-gen11-step4-class-4.mysql.database.azure.com
MYSQL_PORT=3306
MYSQL_USER=student
MYSQL_PASSWORD=your_mysql_password
MYSQL_DATABASE=linemvp
# Azure MySQL Flexible Server は SSL 必須。明示的に false にしない限り true。
MYSQL_SSL=true
# 証明書チェーンの厳格な検証。Node.js 標準 CA で検証できない環境（クラス共有DB等）では false にする。
# 通信自体は MYSQL_SSL=true なら TLS で暗号化される。
MYSQL_SSL_REJECT_UNAUTHORIZED=false

# サーバーポート（App Service が WEBSITES_PORT で渡してくる場合も同値に揃える）
PORT=8080
