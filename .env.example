# LINE Messaging API
LINE_CHANNEL_SECRET=your_line_channel_secret
LINE_CHANNEL_ACCESS_TOKEN=your_line_channel_access_token

# Anthropic Claude API
ANTHROPIC_API_KEY=your_anthropic_api_key
# 任意。未指定なら claude-sonnet-4-5 を使う
ANTHROPIC_MODEL=claude-sonnet-4-5

# Azure Database for MySQL (Flexible Server)
MYSQL_HOST=tech0-gen11-step4-class-4.mysql.database.azure.com
MYSQL_PORT=3306
MYSQL_USER=student
MYSQL_PASSWORD=your_mysql_password
MYSQL_DATABASE=linemvp
# Azure MySQL Flexible Server は SSL 必須。明示的に false にしない限り true。
MYSQL_SSL=true
# 証明書チェーンの厳格な検証。Node.js 標準 CA で検証できない環境（クラス共有DB等）では false にする。
# 通信自体は MYSQL_SSL=true なら TLS で暗号化される。
MYSQL_SSL_REJECT_UNAUTHORIZED=false

# サーバーポート（App Service が WEBSITES_PORT で渡してくる場合も同値に揃える）
PORT=8080

# Phase 3a マッチングしきい値検知 + 通知（任意）
# 同じ認可企業への「話を聞きたい」がこの件数以上集まったら事務局に通知
MATCHING_THRESHOLD=5
# 同会社への通知は直近 N 日以内には1回だけ（重複通知抑制）
NOTIFY_REPEAT_DAYS=7
# Slack incoming webhook URL（未設定時はコンソール出力にフォールバック）
# 取得方法: https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=

# ADMIN エンドポイント (/admin/run-delivery 等) の認証トークン
# GitHub Actions cron や外部スケジューラから叩く際の X-Admin-Token に使う
# 未設定だと管理エンドポイントは 503 を返して無効化される（安全側）
# 値は推測されにくい長いランダム文字列にする（例: openssl rand -hex 32）
ADMIN_TOKEN=

# A3 エラー監視: 同じエラー指紋に対する Slack 重複通知を抑制する時間窓 (秒)
# デフォルト 300 (= 5分)。同じエラーがバースト的に発生しても1度だけ通知される
ERROR_NOTIFY_WINDOW_SECONDS=300

# A3 エラー監視: true でエラー通知機能ごと無効化（緊急停止用）
ERROR_NOTIFY_DISABLED=false

# D1 配信時の Claude 動的推薦理由生成
# true で動的生成を停止、配信は静的テンプレにフォールバック（緊急停止/コスト抑制用）
REASON_AI_DISABLED=false

# B3 LIFF 配信履歴アプリ用
# LINE Developers Console の LINE Login Channel ID（数字）
# 設定しないと /api/me/deliveries は 503 を返す（dev-mock 経路のみ動作）
LIFF_CHANNEL_ID=

# B3 開発モック: 設定すると Authorization: Bearer dev-mock で当該ユーザーとして
# /api/me/deliveries を呼べる。本番では空にしておく
LIFF_DEV_MOCK_USER_ID=
